generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                    String                 @id @default(cuid())
  name                  String
  email                 String                 @unique
  phone                 String?
  website               String?
  address               Json?
  logo                  String?
  businessType          String?
  taxId                 String?
  registrationNumber    String?
  subscriptionPlan      SubscriptionPlan       @default(BASIC)
  subscriptionStatus    SubscriptionStatus     @default(ACTIVE)
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  billingCycle          BillingCycle           @default(MONTHLY)
  timezone              String                 @default("UTC")
  currency              String                 @default("USD")
  dateFormat            String                 @default("MM/dd/yyyy")
  timeFormat            String                 @default("12h")
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  selectedTheme         String?
  setupCompleted        Boolean                @default(false)
  setupData             Json?
  setupProgress         Json?
  teamSize              String?
  accountTransfers      AccountTransfer[]
  appointments          Appointment[]
  auditLogs             AuditLog[]
  branches              Branch[]
  budgets               Budget[]
  cashRegisterDays      CashRegisterDay[]
  clients               Client[]
  settings              CompanySetting[]
  expenseCategories     ExpenseCategory[]
  expenses              Expense[]
  files                 File[]
  financialAccounts     FinancialAccount[]
  financialReports      FinancialReport[]
  financialSettings     FinancialSettings?
  financialTransactions FinancialTransaction[]
  invoices              Invoice[]
  notificationLogs      NotificationLog[]
  payments              Payment[]
  productCategories     ProductCategory[]
  products              Product[]
  reports               Report[]
  sales                 Sale[]
  serviceCategories     ServiceCategory[]
  services              Service[]
  staff                 Staff[]
  taxRates              TaxRate[]
  users                 User[]

  @@index([subscriptionStatus])
  @@index([isActive])
  @@index([subscriptionStatus, isActive])
  @@index([createdAt])
  @@map("companies")
}

model User {
  id                      String     @id @default(cuid())
  email                   String     @unique
  firstName               String
  lastName                String
  phone                   String?
  avatar                  String?
  password                String
  companyId               String
  role                    UserRole   @default(USER)
  permissions             Json?
  isActive                Boolean    @default(true)
  isVerified              Boolean    @default(false)
  lastLoginAt             DateTime?
  resetToken              String?
  resetTokenExpiry        DateTime?
  verificationToken       String?
  verificationTokenExpiry DateTime?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  auditLogs               AuditLog[]
  createdClients          Client[]
  createdInvoices         Invoice[]
  createdPayments         Payment[]
  staffProfile            Staff?
  company                 Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([email])
  @@index([isActive])
  @@index([companyId, isActive])
  @@index([companyId, role])
  @@index([lastLoginAt])
  @@map("users")
}

model Branch {
  id                    String                 @id @default(cuid())
  name                  String
  address               Json
  phone                 String?
  email                 String?
  companyId             String
  isMain                Boolean                @default(false)
  isActive              Boolean                @default(true)
  operatingHours        Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  contact               Json?
  coordinates           Json?
  resources             String[]               @default([])
  services              String[]               @default([])
  settings              Json?
  staffIds              String[]               @default([])
  status                BranchStatus           @default(ACTIVE)
  type                  BranchType             @default(SECONDARY)
  appointments          Appointment[]
  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  budgets               Budget[]
  cashRegisterDays      CashRegisterDay[]
  expenses              Expense[]
  financialAccounts     FinancialAccount[]
  financialReports      FinancialReport[]
  financialTransactions FinancialTransaction[]
  inventories           Inventory[]
  inventoryMovements    InventoryMovement[]
  invoices              Invoice[]
  notificationLogs      NotificationLog[]
  sales                 Sale[]
  serviceBranches       ServiceBranch[]
  primaryStaff          Staff[]                @relation("StaffPrimaryBranch")
  staffAssignments      StaffBranch[]          @relation("StaffBranchAssignments")
  staffSchedules        StaffSchedule[]

  @@index([companyId])
  @@index([type])
  @@index([status])
  @@index([isActive])
  @@index([companyId, status])
  @@index([companyId, isActive])
  @@map("branches")
}

model Client {
  id                     String              @id @default(cuid())
  companyId              String
  firstName              String
  lastName               String
  email                  String?
  phone                  String?
  dateOfBirth            DateTime?
  gender                 Gender?
  address                Json?
  preferredLanguage      String?
  preferredCommunication CommunicationMethod @default(EMAIL)
  allergies              String?
  medicalConditions      String?
  notes                  String?
  marketingConsent       Boolean             @default(false)
  reminderPreferences    Json?
  status                 ClientStatus        @default(ACTIVE)
  isActive               Boolean             @default(true)
  createdById            String
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  appointments           Appointment[]
  company                Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy              User                @relation(fields: [createdById], references: [id])
  invoices               Invoice[]
  payments               Payment[]
  sales                  Sale[]

  @@index([companyId])
  @@index([email])
  @@index([status])
  @@index([isActive])
  @@index([companyId, status])
  @@index([companyId, isActive])
  @@index([companyId, createdAt])
  @@index([createdAt])
  @@map("clients")
}

model Staff {
  id                   String          @id @default(cuid())
  companyId            String
  userId               String?         @unique
  firstName            String?
  lastName             String?
  email                String?
  phone                String?
  avatar               String?
  employeeId           String?
  position             String?
  department           String?
  specializations      String[]
  certifications       Json?
  qualifications       String?
  bio                  String?
  commissionRate       Decimal?        @db.Decimal(5, 4)
  hourlyRate           Decimal?        @db.Decimal(8, 2)
  status               StaffStatus     @default(ACTIVE)
  isActive             Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  accessLevel          AccessLevel     @default(EMPLOYEE)
  accessStatus         AccessStatus    @default(NOT_GRANTED)
  citizenship          String?
  color                String?
  createdBy            String?
  defaultTemplate      String?
  displayOrder         Int?
  employmentDate       DateTime?
  gender               Gender?
  insuranceNumber      String?
  inviteSentAt         DateTime?
  isScheduled          Boolean         @default(false)
  lastLoginAt          DateTime?
  middleName           String?
  name                 String
  onlineBookingEnabled Boolean         @default(false)
  onlineBookingProfile Json?
  onlineBookingRules   Json?
  passport             String?
  positionId           String?
  primaryBranchId      String?
  registrationEndDate  DateTime?
  scheduleStartDate    DateTime?
  scheduledUntil       DateTime?
  schedulingTime       String?
  servicesCount        Int             @default(0)
  specialization       String?
  taxId                String?
  workingHours         Json?
  image                String?
  mobile               String?
  nameAr               String?
  order                Int             @default(0)
  title                String?
  appointments         Appointment[]
  sales                Sale[]
  company              Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  primaryBranch        Branch?         @relation("StaffPrimaryBranch", fields: [primaryBranchId], references: [id])
  user                 User?           @relation(fields: [userId], references: [id])
  branches             StaffBranch[]
  schedules            StaffSchedule[]
  services             StaffService[]
  timeOffs             StaffTimeOff[]

  @@index([companyId])
  @@index([primaryBranchId])
  @@index([positionId])
  @@index([accessLevel])
  @@index([status])
  @@index([isActive])
  @@index([email])
  @@index([order])
  @@index([companyId, status])
  @@index([companyId, isActive])
  @@index([companyId, primaryBranchId])
  @@index([primaryBranchId, status])
  @@map("staff")
}

model Service {
  id            String           @id @default(cuid())
  companyId     String
  name          String
  description   String?
  color         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  active        Boolean          @default(true)
  apiId         String?
  autoDeduction Boolean          @default(false)
  branchId      String?
  branchIds     String[]         @default([])
  categoryId    String?
  createdBy     String?
  descriptionAr String?
  followUpDays  Int?
  images        Json?
  invoiceName   String?
  nameAr        String?
  onlineBooking Json
  order         Int              @default(0)
  priceRange    Json?
  startingPrice Decimal          @db.Decimal(10, 2)
  taxSystem     String?
  translations  Json?
  type          ServiceType      @default(APPOINTMENT)
  vat           Decimal?         @db.Decimal(5, 4)
  duration      Json
  saleItems     SaleItem[]
  branches      ServiceBranch[]
  category      ServiceCategory? @relation(fields: [categoryId], references: [id])
  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  staffServices StaffService[]

  @@index([companyId])
  @@index([categoryId])
  @@index([active])
  @@index([type])
  @@index([order])
  @@index([companyId, active])
  @@index([companyId, categoryId])
  @@index([companyId, type])
  @@map("services")
}

model ServiceCategory {
  id                   String    @id @default(cuid())
  companyId            String
  branchId             String?
  name                 String
  nameAr               String?
  useOnlineBookingName Boolean   @default(false)
  onlineBookingName    String?
  servicesCount        Int       @default(0)
  description          String?
  color                String?
  icon                 String?
  order                Int       @default(0)
  active               Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  createdBy            String?
  company              Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  services             Service[]

  @@index([companyId])
  @@index([branchId])
  @@index([active])
  @@index([order])
  @@map("service_categories")
}

model ServiceBranch {
  id        String  @id @default(cuid())
  serviceId String
  branchId  String
  isActive  Boolean @default(true)
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, branchId])
  @@map("service_branches")
}

model StaffBranch {
  id        String   @id @default(cuid())
  staffId   String
  branchId  String
  isPrimary Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  branch    Branch   @relation("StaffBranchAssignments", fields: [branchId], references: [id], onDelete: Cascade)
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, branchId])
  @@index([staffId])
  @@index([branchId])
  @@map("staff_branches")
}

model StaffService {
  id              String   @id @default(cuid())
  staffId         String
  serviceId       String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  billOfMaterials String?
  duration        Json?
  price           Decimal? @db.Decimal(10, 2)
  service         Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff           Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, serviceId])
  @@map("staff_services")
}

model StaffSchedule {
  id           String       @id @default(cuid())
  staffId      String
  startDate    DateTime
  endDate      DateTime?
  dayOfWeek    Int
  startTime    String
  endTime      String
  breaks       Json?
  type         ScheduleType @default(REGULAR)
  isWorking    Boolean      @default(true)
  overrideDate DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  branchId     String
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  staff        Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, branchId, dayOfWeek])
  @@index([staffId])
  @@index([branchId])
  @@index([startDate])
  @@index([dayOfWeek])
  @@map("staff_schedules")
}

model Appointment {
  id                 String                @id @default(cuid())
  companyId          String
  title              String?
  startTime          String
  endTime            String
  clientId           String
  staffId            String?
  branchId           String
  notes              String?
  internalNotes      String?
  status             AppointmentStatus     @default(PENDING)
  reminderSent       Boolean               @default(false)
  cancellationReason String?
  cancelledAt        DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  bookingLinkId      String?
  cancelledBy        String?
  categoryId         String?
  changeHistory      Json?
  clientEmail        String?
  clientName         String
  clientPhone        String
  color              String?
  createdBy          String?
  date               DateTime
  discount           Decimal?              @db.Decimal(10, 2)
  duration           Int?
  isNewClient        Boolean               @default(false)
  isRecurring        Boolean               @default(false)
  lastModifiedBy     String?
  notifications      Json?
  paidAmount         Decimal               @default(0) @db.Decimal(10, 2)
  paymentStatus      PaymentStatus         @default(PENDING)
  prepaidAmount      Decimal?              @db.Decimal(10, 2)
  recurringGroupId   String?
  recurringPattern   Json?
  repeat             Json?
  repeatGroupId      String?
  rescheduledAt      DateTime?
  rescheduledTo      String?
  resourceId         String?
  resources          Json?
  services           Json
  source             AppointmentSource     @default(DASHBOARD)
  staffName          String?
  startingPrice      Decimal?              @db.Decimal(10, 2)
  totalDuration      Int
  totalPrice         Decimal               @db.Decimal(10, 2)
  invoices           AppointmentInvoice[]
  reminders          AppointmentReminder[]
  branch             Branch                @relation(fields: [branchId], references: [id])
  client             Client                @relation(fields: [clientId], references: [id])
  company            Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  staff              Staff?                @relation(fields: [staffId], references: [id])
  invoice            Invoice?

  @@index([companyId, branchId, date])
  @@index([clientId])
  @@index([staffId])
  @@index([date, startTime])
  @@index([status])
  @@index([recurringGroupId])
  @@index([source])
  @@index([companyId, status])
  @@index([branchId, date, status])
  @@index([staffId, date, startTime])
  @@index([clientId, createdAt])
  @@index([date, status])
  @@index([companyId, date, status])
  @@map("appointments")
}

model AppointmentReminder {
  id            String       @id @default(cuid())
  appointmentId String
  scheduledFor  DateTime
  sent          Boolean      @default(false)
  sentAt        DateTime?
  error         String?
  type          ReminderType
  appointment   Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([scheduledFor, sent])
  @@map("appointment_reminders")
}

model AppointmentWaitlist {
  id               String   @id @default(cuid())
  companyId        String
  branchId         String
  clientId         String
  serviceIds       Json
  preferredStaffId String?
  preferredDate    DateTime
  flexibleDates    Boolean  @default(false)
  notes            String?
  status           String   @default("WAITING")
  createdAt        DateTime @default(now())

  @@index([branchId, preferredDate])
  @@map("appointment_waitlist")
}

model Invoice {
  id              String               @id @default(cuid())
  companyId       String
  invoiceNumber   String
  title           String?
  clientId        String
  issueDate       DateTime             @default(now())
  dueDate         DateTime
  subtotal        Decimal              @default(0) @db.Decimal(10, 2)
  taxRate         Decimal              @default(0) @db.Decimal(5, 4)
  taxAmount       Decimal              @default(0) @db.Decimal(10, 2)
  discountAmount  Decimal              @default(0) @db.Decimal(10, 2)
  total           Decimal              @default(0) @db.Decimal(10, 2)
  status          InvoiceStatus        @default(DRAFT)
  paidAmount      Decimal              @default(0) @db.Decimal(10, 2)
  notes           String?
  terms           String?
  createdById     String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  appointmentId   String?              @unique
  balanceAmount   Decimal              @default(0) @db.Decimal(10, 2)
  branchId        String
  cancelledAt     DateTime?
  currency        String               @default("EGP")
  discountType    String?
  discountValue   Decimal?             @db.Decimal(10, 2)
  internalNotes   String?
  invoiceDate     DateTime             @default(now())
  paidAt          DateTime?
  paymentStatus   PaymentStatus        @default(PENDING)
  sentAt          DateTime?
  termsConditions String?
  viewedAt        DateTime?
  appointments    AppointmentInvoice[]
  items           InvoiceItem[]
  appointment     Appointment?         @relation(fields: [appointmentId], references: [id])
  branch          Branch               @relation(fields: [branchId], references: [id])
  client          Client               @relation(fields: [clientId], references: [id])
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy       User                 @relation(fields: [createdById], references: [id])
  payments        Payment[]
  sales           Sale[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([branchId])
  @@index([clientId])
  @@index([appointmentId])
  @@index([status])
  @@index([paymentStatus])
  @@index([dueDate])
  @@index([invoiceDate])
  @@index([companyId, status])
  @@index([companyId, paymentStatus])
  @@index([branchId, status])
  @@index([clientId, status])
  @@index([companyId, dueDate])
  @@index([status, dueDate])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal  @db.Decimal(10, 3)
  unitPrice   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  order       Int      @default(0)
  discount    Decimal? @db.Decimal(10, 2)
  itemId      String?
  taxRate     Decimal? @db.Decimal(5, 4)
  type        String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([type])
  @@index([itemId])
  @@map("invoice_items")
}

model AppointmentInvoice {
  id            String      @id @default(cuid())
  appointmentId String
  invoiceId     String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  invoice       Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, invoiceId])
  @@map("appointment_invoices")
}

model Payment {
  id             String        @id @default(cuid())
  companyId      String
  amount         Decimal       @db.Decimal(10, 2)
  paymentDate    DateTime      @default(now())
  paymentMethod  PaymentMethod
  clientId       String
  invoiceId      String
  transactionId  String?
  paymentGateway String?
  status         PaymentStatus @default(PENDING)
  notes          String?
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  processedAt    DateTime?
  reference      String?
  client         Client        @relation(fields: [clientId], references: [id])
  company        Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy      User          @relation(fields: [createdById], references: [id])
  invoice        Invoice       @relation(fields: [invoiceId], references: [id])

  @@index([companyId])
  @@index([clientId])
  @@index([invoiceId])
  @@index([status])
  @@index([paymentDate])
  @@map("payments")
}

model StaffTimeOff {
  id        String        @id @default(cuid())
  staffId   String
  startDate DateTime
  endDate   DateTime
  type      TimeOffType
  reason    String?
  status    TimeOffStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  staff     Staff         @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([startDate])
  @@map("staff_time_offs")
}

model CompanySetting {
  id        String   @id @default(cuid())
  companyId String
  key       String
  value     Json
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
  @@index([companyId])
  @@index([category])
  @@map("company_settings")
}

model Report {
  id          String       @id @default(cuid())
  companyId   String
  name        String
  type        ReportType
  parameters  Json?
  data        Json?
  isScheduled Boolean      @default(false)
  schedule    String?
  status      ReportStatus @default(DRAFT)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([type])
  @@map("reports")
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String
  userId     String?
  action     String
  resource   String
  resourceId String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

model Product {
  id                String              @id @default(cuid())
  companyId         String
  name              String
  nameAr            String?
  description       String?
  descriptionAr     String?
  sku               String?
  barcode           String?
  categoryId        String?
  price             Decimal             @db.Decimal(10, 2)
  cost              Decimal?            @db.Decimal(10, 2)
  taxRate           Decimal             @default(0) @db.Decimal(5, 4)
  trackInventory    Boolean             @default(true)
  stock             Int                 @default(0)
  lowStockThreshold Int?
  variants          Json?
  images            String[]
  active            Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  inventories       Inventory[]
  movements         InventoryMovement[]
  category          ProductCategory?    @relation(fields: [categoryId], references: [id])
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  saleItems         SaleItem[]

  @@index([companyId])
  @@index([categoryId])
  @@index([sku])
  @@index([barcode])
  @@index([active])
  @@map("products")
}

model ProductCategory {
  id          String            @id @default(cuid())
  companyId   String
  name        String
  nameAr      String?
  description String?
  parentId    String?
  order       Int               @default(0)
  color       String?
  icon        String?
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent      ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    ProductCategory[] @relation("CategoryHierarchy")
  products    Product[]

  @@index([companyId])
  @@index([parentId])
  @@index([active])
  @@map("product_categories")
}

model Inventory {
  id               String    @id @default(cuid())
  productId        String
  branchId         String
  quantity         Int       @default(0)
  reservedQuantity Int       @default(0)
  lastRestocked    DateTime?
  lastCountDate    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  branch           Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product          Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId])
  @@index([productId])
  @@index([branchId])
  @@map("inventories")
}

model InventoryMovement {
  id            String                @id @default(cuid())
  productId     String
  branchId      String
  type          InventoryMovementType
  quantity      Int
  reference     String?
  referenceType String?
  notes         String?
  unitCost      Decimal?              @db.Decimal(10, 2)
  performedBy   String?
  createdAt     DateTime              @default(now())
  branch        Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
