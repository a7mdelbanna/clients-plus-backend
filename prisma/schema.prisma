// ============================================================================
// PRODUCT AND INVENTORY MANAGEMENT
// ============================================================================

model Product {
  id String @id @default(cuid())

  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Basic product information
  name          String
  nameAr        String? // Arabic name
  description   String?
  descriptionAr String?
  sku           String? // Stock Keeping Unit
  barcode       String? // Product barcode

  // Category and classification
  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id])

  // Pricing
  price   Decimal  @db.Decimal(10, 2) // Base selling price
  cost    Decimal? @db.Decimal(10, 2) // Cost price
  taxRate Decimal  @default(0) @db.Decimal(5, 4) // Tax rate

  // Inventory tracking
  trackInventory    Boolean @default(true)
  stock             Int     @default(0) // Total stock across all branches
  lowStockThreshold Int? // Alert threshold

  // Product variants and attributes
  variants Json? // Product variants (color, size, etc.)
  images   String[] // Product images URLs

  // Status and visibility
  active Boolean @default(true)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  inventories Inventory[]
  movements   InventoryMovement[]
  saleItems   SaleItem[]

  @@index([companyId])
  @@index([categoryId])
  @@index([sku])
  @@index([barcode])
  @@index([active])
  @@map("products")
}

model ProductCategory {
  id String @id @default(cuid())

  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Category information
  name        String
  nameAr      String?
  description String?

  // Hierarchy
  parentId String?
  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")

  // Display settings
  order Int     @default(0)
  color String? // For UI display
  icon  String? // Icon identifier

  // Status
  active Boolean @default(true)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  products Product[]

  @@index([companyId])
  @@index([parentId])
  @@index([active])
  @@map("product_categories")
}

model Inventory {
  id String @id @default(cuid())

  // Product and branch relationship
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  // Stock levels
  quantity         Int @default(0) // Available quantity
  reservedQuantity Int @default(0) // Reserved for orders/appointments

  // Stock management
  lastRestocked DateTime? // Last restock date
  lastCountDate DateTime? // Last physical count

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, branchId])
  @@index([productId])
  @@index([branchId])
  @@map("inventories")
}

model InventoryMovement {
  id String @id @default(cuid())

  // Product and branch
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  // Movement details
  type     InventoryMovementType
  quantity Int // Positive for IN, negative for OUT

  // Reference information
  reference     String? // Order ID, Transfer ID, etc.
  referenceType String? // 'sale', 'purchase', 'transfer', 'adjustment'

  // Additional details
  notes    String?
  unitCost Decimal? @db.Decimal(10, 2) // Cost at time of movement

  // User tracking
  performedBy String? // User who performed the action

  // Metadata
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([branchId])
  @@index([type])
  @@index([createdAt])
  @@map("inventory_movements")
}

enum InventoryMovementType {
  IN // Stock received
  OUT // Stock sold/used
  TRANSFER // Transfer between branches
  ADJUSTMENT // Manual adjustment
}

// ============================================================================
// NOTIFICATION SYSTEM
// ============================================================================

model NotificationLog {
  id String @id @default(cuid())

  // Job tracking
  jobId      String  @unique // Unique job identifier
  queueJobId String? // Bull queue job ID

  // Notification details
  type      NotificationType
  companyId String
  company   Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId  String?
  branch    Branch?          @relation(fields: [branchId], references: [id])

  // Recipient information
  recipient      String // Recipient name
  recipientPhone String? // Phone number
  recipientEmail String? // Email address

  // Status and result
  status   NotificationStatus   @default(PENDING)
