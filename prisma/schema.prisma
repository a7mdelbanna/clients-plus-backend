  alertSent      Boolean  @default(false)
  
  // Status
  isActive Boolean @default(true)
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  
  @@index([companyId])
  @@index([branchId])
  @@index([budgetType])
  @@index([periodStart, periodEnd])
  @@index([isActive])
  @@map("budgets")
