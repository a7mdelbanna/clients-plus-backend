  // Export
  exportUrl    String?
  exportFormat String? // PDF, EXCEL, CSV
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  
  @@index([companyId])
  @@index([reportType])
  @@index([startDate, endDate])
  @@index([status])
  @@map("financial_reports")
}

// Update Company model to include financial relations
model FinancialSettings {
  id String @id @default(cuid())
  
  // Multi-tenant relationship
  companyId String @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Default accounts
  defaultCashAccount     String?
  defaultBankAccount     String?
  defaultIncomeAccount   String?
  defaultExpenseAccount  String?
  
  // Fiscal year
  fiscalYearStart DateTime
  fiscalYearEnd   DateTime
  
  // Currency settings
  baseCurrency           String @default("EGP")
  supportedCurrencies    String[] @default(["EGP"])
  exchangeRateProvider   String?
  
  // Tax settings
  defaultTaxRate         Decimal? @db.Decimal(5, 4)
  taxIdNumber            String?
  vatRegistrationNumber  String?
  
  // Approval workflows
  requireExpenseApproval Boolean @default(true)
  expenseApprovalLimit   Decimal? @db.Decimal(15, 2)
  requireTransferApproval Boolean @default(false)
  transferApprovalLimit  Decimal? @db.Decimal(15, 2)
  
  // Reconciliation
  autoReconciliation     Boolean @default(false)
  reconciliationTolerance Decimal? @db.Decimal(10, 2)
  
  // Integration settings
  bankIntegration        Json? // Bank API settings
  accountingIntegration  Json? // Third-party accounting integration
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("financial_settings")
}

// ============================================================================
// SALES AND POS MODELS
// ============================================================================

model Sale {
  id String @id @default(cuid())
  
  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Transaction details
  saleNumber   String   @unique
  saleDate     DateTime @default(now())
  
  // Location and staff
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])
  
  staffId String?
  staff   Staff?  @relation(fields: [staffId], references: [id])
  
  // Customer (optional for POS sales)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])
  
  // Items and pricing
  items         SaleItem[]
  subtotal      Decimal @db.Decimal(15, 2)
  discountType  DiscountType @default(FIXED)
  discountValue Decimal @default(0) @db.Decimal(15, 2)
  discountAmount Decimal @default(0) @db.Decimal(15, 2)
  taxAmount     Decimal @default(0) @db.Decimal(15, 2)
  total         Decimal @db.Decimal(15, 2)
  
  // Payment information
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(COMPLETED)
  amountPaid    Decimal @db.Decimal(15, 2)
  changeDue     Decimal @default(0) @db.Decimal(15, 2)
  
  // Reference numbers
  receiptNumber String?
  invoiceId     String? // Link to generated invoice if needed
  invoice       Invoice? @relation(fields: [invoiceId], references: [id])
  
  // Status
  status SaleStatus @default(COMPLETED)
  
  // Additional information
  notes         String?
  internalNotes String?
  
  // Refund tracking
  refunds       SaleRefund[]
  isRefunded    Boolean @default(false)
  refundedAmount Decimal @default(0) @db.Decimal(15, 2)
  
  // Cash register reference
  registerDayId String?
  registerDay   CashRegisterDay? @relation(fields: [registerDayId], references: [id])
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  
  @@index([companyId])
  @@index([branchId])
  @@index([clientId])
  @@index([staffId])
  @@index([saleDate])
  @@index([paymentMethod])
  @@index([status])
  @@index([registerDayId])
  @@map("sales")
}

model SaleItem {
  id String @id @default(cuid())
  
  // Sale relationship
  saleId String
  sale   Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  // Item details
  type        ItemType @default(PRODUCT)
  productId   String? // For product items
  product     Product? @relation(fields: [productId], references: [id])
  serviceId   String? // For service items  
  service     Service? @relation(fields: [serviceId], references: [id])
  
  // Item information
  name        String // Item name at time of sale
  description String?
  sku         String? // Product SKU if applicable
  
  // Pricing
  unitPrice   Decimal @db.Decimal(15, 2)
  quantity    Decimal @db.Decimal(15, 4)
  discount    Decimal @default(0) @db.Decimal(15, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 4)
  taxAmount   Decimal @default(0) @db.Decimal(15, 2)
  lineTotal   Decimal @db.Decimal(15, 2)
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([saleId])
  @@index([productId])
  @@index([serviceId])
  @@map("sale_items")
}

model SaleRefund {
  id String @id @default(cuid())
  
  // Sale relationship
  saleId String
  sale   Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  // Refund details
  refundNumber String   @unique
  refundDate   DateTime @default(now())
  amount       Decimal  @db.Decimal(15, 2)
  reason       String?
  
  // Refund items (which specific items were refunded)
  refundItems Json? // Array of {itemId, quantity, amount}
  
  // Payment details
  refundMethod    PaymentMethod
  refundReference String? // Reference number for refund transaction
  
  // Status
  status RefundStatus @default(COMPLETED)
  
  // Processing information
  processedBy String?
  processedAt DateTime @default(now())
  
  // Notes
  notes String?
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([saleId])
  @@index([refundDate])
  @@index([status])
  @@map("sale_refunds")
}

// ============================================================================
// FILE STORAGE MODEL
// ============================================================================

model File {
  id String @id @default(cuid())
  
  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // File details
  fileName     String
  mimeType     String
  size         Int
  type         String // avatar, service, document, logo, invoice
  url          String
  thumbnailUrl String?
  
  // Upload information
  uploadedBy String
  uploadedAt DateTime @default(now())
  
  // Metadata
  metadata  Json?
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([companyId])
  @@index([type])
  @@index([uploadedBy])
  @@map("files")
}

