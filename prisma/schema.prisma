// ============================================================================
// FINANCIAL MANAGEMENT SYSTEM
// ============================================================================

model FinancialAccount {
  id String @id @default(cuid())

  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Branch relationship (optional for company-wide accounts)
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  // Account details
  name          String // Account name
  accountNumber String? // Account number or reference
  accountType   FinancialAccountType
  subType       String? // Detailed sub-categorization

  // Balance tracking
  balance         Decimal @default(0) @db.Decimal(15, 2)
  initialBalance  Decimal @default(0) @db.Decimal(15, 2)
  availableBalance Decimal @default(0) @db.Decimal(15, 2) // For credit accounts

  // Currency and limits
  currency     String  @default("EGP")
  creditLimit  Decimal? @db.Decimal(15, 2)
  minimumBalance Decimal? @db.Decimal(15, 2)

  // Bank details (for bank accounts)
  bankName     String?
  bankBranch   String?
  iban         String?
  swiftCode    String?
  routingNumber String?

  // Account configuration
  isDefault    Boolean @default(false) // Default account for this type
  isActive     Boolean @default(true)
  allowOverdraft Boolean @default(false)

  // Reconciliation
  lastReconciledDate DateTime?
  lastReconciledBalance Decimal? @db.Decimal(15, 2)

  // Metadata
  description String?
  tags        String[] @default([])
  notes       String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  // Relations
  transactions     FinancialTransaction[]
  fromTransfers    AccountTransfer[] @relation("FromAccount")
  toTransfers      AccountTransfer[] @relation("ToAccount")
  cashRegisterDays CashRegisterDay[]
  budgets          Budget[]

  @@unique([companyId, accountNumber])
  @@index([companyId])
  @@index([branchId])
  @@index([accountType])
  @@index([isActive])
  @@index([currency])
  @@map("financial_accounts")
}

model FinancialTransaction {
  id String @id @default(cuid())

  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Account relationship
  accountId String
  account   FinancialAccount @relation(fields: [accountId], references: [id])

  // Branch relationship
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  // Transaction details
  type        FinancialTransactionType
  category    String? // Income/Expense category
  subcategory String? // Detailed subcategory
  
  amount      Decimal @db.Decimal(15, 2)
  description String
  reference   String? // Invoice number, check number, etc.
  
  // Transaction metadata
  transactionDate DateTime @default(now())
  effectiveDate   DateTime? // When the transaction should be effective
  
  // Payment method and details
  paymentMethod PaymentMethod?
  checkNumber   String?
  
  // Related entities
  invoiceId     String? // Link to invoice
  appointmentId String? // Link to appointment
  clientId      String? // Link to client
  vendorId      String? // Link to vendor/supplier
  expenseId     String? // Link to expense record
  
  // Status and approval
  status       TransactionStatus @default(PENDING)
  approvedBy   String? // User who approved
  approvedAt   DateTime?
  
  // Reconciliation
  isReconciled    Boolean @default(false)
  reconciledAt    DateTime?
  reconciledBy    String?
  bankStatement   String? // Bank statement reference
  
  // Currency handling
  currency         String @default("EGP")
  exchangeRate     Decimal? @db.Decimal(10, 6)
  originalAmount   Decimal? @db.Decimal(15, 2)
  originalCurrency String?
  
  // Tax information
  taxAmount     Decimal? @db.Decimal(15, 2)
  taxRate       Decimal? @db.Decimal(5, 4)
  taxCategory   String?
  isVatApplicable Boolean @default(false)
  
  // Additional details
  attachments   Json? // Array of attachment URLs
  tags          String[] @default([])
  notes         String?
  internalNotes String?
  
  // Running balance (for performance)
  runningBalance Decimal? @db.Decimal(15, 2)
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  
  @@index([companyId])
  @@index([accountId])
  @@index([branchId])
  @@index([type])
  @@index([category])
  @@index([status])
  @@index([transactionDate])
  @@index([isReconciled])
  @@index([invoiceId])
  @@index([clientId])
  @@index([companyId, transactionDate])
  @@index([accountId, transactionDate])
  @@map("financial_transactions")
}

model AccountTransfer {
  id String @id @default(cuid())

  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Account relationships
  fromAccountId String
  fromAccount   FinancialAccount @relation("FromAccount", fields: [fromAccountId], references: [id])
  
  toAccountId String
  toAccount   FinancialAccount @relation("ToAccount", fields: [toAccountId], references: [id])

  // Transfer details
  amount      Decimal @db.Decimal(15, 2)
  description String
  reference   String?
  
  // Transfer fees
  transferFee Decimal? @db.Decimal(15, 2)
  feeAccount  String? // Account to debit transfer fee
  
  // Currency exchange
  exchangeRate       Decimal? @db.Decimal(10, 6)
  fromCurrency       String   @default("EGP")
  toCurrency         String   @default("EGP")
  fromCurrencyAmount Decimal? @db.Decimal(15, 2)
  toCurrencyAmount   Decimal? @db.Decimal(15, 2)
  
  // Status and approval
  status     TransferStatus @default(PENDING)
  approvedBy String?
  approvedAt DateTime?
  
  // Metadata
  transferDate DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?
  
  @@index([companyId])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([status])
  @@index([transferDate])
  @@map("account_transfers")
}

model ExpenseCategory {
  id String @id @default(cuid())

  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Category details
  name        String
  description String?
  code        String? // Category code for reporting
  
  // Hierarchy support
  parentId String?
  parent   ExpenseCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ExpenseCategory[] @relation("CategoryHierarchy")
  
  // Budget and limits
  budgetLimit  Decimal? @db.Decimal(15, 2)
  alertLimit   Decimal? @db.Decimal(15, 2)
  requiresApproval Boolean @default(false)
  
  // Tax settings
  defaultTaxRate     Decimal? @db.Decimal(5, 4)
  isDeductible       Boolean  @default(true)
  deductiblePercent  Decimal? @db.Decimal(5, 2)
  
  // Status
  isActive Boolean @default(true)
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  
  // Relations
  expenses Expense[]
  budgets  Budget[]
  
  @@unique([companyId, code])
  @@index([companyId])
  @@index([parentId])
  @@index([isActive])
  @@map("expense_categories")
}

model Expense {
  id String @id @default(cuid())

  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Branch relationship
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  // Category
  categoryId String?
  category   ExpenseCategory? @relation(fields: [categoryId], references: [id])

  // Expense details
  title        String
  description  String?
  amount       Decimal @db.Decimal(15, 2)
  currency     String  @default("EGP")
  
  // Tax details
  taxAmount    Decimal? @db.Decimal(15, 2)
  taxRate      Decimal? @db.Decimal(5, 4)
  netAmount    Decimal? @db.Decimal(15, 2)
  
  // Vendor information
  vendorName   String?
  vendorId     String? // Reference to vendor if exists
  
  // Payment information
  paymentMethod PaymentMethod?
  accountId     String? // Account used for payment
  checkNumber   String?
  reference     String? // Invoice/receipt reference
  
  // Dates
  expenseDate DateTime
  paidDate    DateTime?
  dueDate     DateTime?
  
  // Approval workflow
  status          ExpenseStatus @default(DRAFT)
  submittedBy     String? // Employee who submitted
  submittedAt     DateTime?
  approvedBy      String? // Manager who approved
  approvedAt      DateTime?
  rejectedBy      String?
  rejectedAt      DateTime?
  rejectionReason String?
  
  // Reimbursement (for employee expenses)
  isReimbursable     Boolean @default(false)
  reimbursementStatus ReimbursementStatus @default(NOT_APPLICABLE)
  reimbursedAmount   Decimal? @db.Decimal(15, 2)
  reimbursedDate     DateTime?
  
  // Recurring expenses
  isRecurring      Boolean @default(false)
  recurringPattern Json? // Recurrence configuration
  parentExpenseId  String? // For recurring expenses
  
  // Receipt and documentation
  hasReceipt    Boolean @default(false)
  receiptUrl    String?
  attachments   Json? // Array of attachment URLs
  
  // Additional fields
  tags          String[] @default([])
  notes         String?
  internalNotes String?
  
  // Integration
  transactionId String? // Linked financial transaction
  
  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  
  @@index([companyId])
  @@index([branchId])
  @@index([categoryId])
  @@index([status])
  @@index([expenseDate])
  @@index([submittedBy])
  @@index([approvedBy])
  @@index([isReimbursable])
  @@index([companyId, expenseDate])
  @@index([companyId, status])
  @@map("expenses")
}

model Budget {
  id String @id @default(cuid())

  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Branch relationship (optional for company-wide budgets)
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  // Budget scope
  name        String
  description String?
  budgetType  BudgetType
  
