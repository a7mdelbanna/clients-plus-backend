// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// MULTI-TENANT ARCHITECTURE - COMPANIES
// ============================================================================

model Company {
  id      String  @id @default(cuid())
  name    String
  email   String  @unique
  phone   String?
  website String?
  address Json?
  logo    String?

  // Business settings
  businessType       String?
  taxId              String?
  registrationNumber String?

  // Subscription and billing
  subscriptionPlan      SubscriptionPlan   @default(BASIC)
  subscriptionStatus    SubscriptionStatus @default(ACTIVE)
  subscriptionStartDate DateTime?
  subscriptionEndDate   DateTime?
  billingCycle          BillingCycle       @default(MONTHLY)

  // Company configuration
  timezone   String @default("UTC")
  currency   String @default("USD")
  dateFormat String @default("MM/dd/yyyy")
  timeFormat String @default("12h")

  // Setup wizard tracking
  setupCompleted Boolean @default(false)
  setupProgress  Json? // Track which steps are completed: {businessInfo: true, branches: false, ...}
  setupData      Json? // Store setup configuration data temporarily
  teamSize       String? // Team size selection
  selectedTheme  String? // Theme selection

  // Status and metadata
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users             User[]
  branches          Branch[]
  clients           Client[]
  services          Service[]
  serviceCategories ServiceCategory[]
  staff             Staff[]
  appointments      Appointment[]
  invoices          Invoice[]
  payments          Payment[]
  reports           Report[]
  settings          CompanySetting[]
  auditLogs         AuditLog[]
  products          Product[]
  productCategories ProductCategory[]
  notificationLogs  NotificationLog[]
  
  // Financial relations
  financialAccounts    FinancialAccount[]
  financialTransactions FinancialTransaction[]
  accountTransfers     AccountTransfer[]
  expenseCategories    ExpenseCategory[]
  expenses             Expense[]
  budgets              Budget[]
  cashRegisterDays     CashRegisterDay[]
  taxRates             TaxRate[]
  financialReports     FinancialReport[]
  financialSettings    FinancialSettings?
  
  // File storage
  files                File[]
  
  // Sales relations
  sales                Sale[]

  @@index([subscriptionStatus])
  @@index([isActive])
  @@index([subscriptionStatus, isActive])
  @@index([createdAt])
  @@map("companies")
}

// ============================================================================
// USERS AND AUTHENTICATION
// ============================================================================

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  firstName String
  lastName  String
  phone     String?
  avatar    String?
  password  String

  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Role and permissions
  role        UserRole @default(USER)
  permissions Json? // Custom permissions JSON

  // Account status
  isActive    Boolean   @default(true)
  isVerified  Boolean   @default(false)
  lastLoginAt DateTime?

  // Password reset
  resetToken       String?
  resetTokenExpiry DateTime?

  // Email verification
  verificationToken       String?
  verificationTokenExpiry DateTime?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  staffProfile    Staff?
  createdClients  Client[]
  createdInvoices Invoice[]
  createdPayments Payment[]
  auditLogs       AuditLog[]

  @@index([companyId])
  @@index([email])
  @@index([isActive])
  @@index([companyId, isActive])
  @@index([companyId, role])
  @@index([lastLoginAt])
  @@map("users")
}

// ============================================================================
// BRANCHES
// ============================================================================

model Branch {
  id      String  @id @default(cuid())
  name    String
  address Json
  phone   String?
  email   String?

  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Branch type and status
  type   BranchType   @default(SECONDARY)
  status BranchStatus @default(ACTIVE)

  // Legacy fields for compatibility
  isMain   Boolean @default(false) // Deprecated: use type instead
  isActive Boolean @default(true) // Deprecated: use status instead

  // Location and coordinates
  coordinates Json? // {lat: number, lng: number}

  // Contact information (expanded)
  contact Json? // {phones: PhoneNumber[], email?: string}

  // Operating hours (JSON structure for flexible scheduling)
  operatingHours Json? // {[day: string]: DaySchedule}

  // Branch assignments
  services  String[] @default([]) // Service IDs available at branch
  resources String[] @default([]) // Resource IDs at branch
  staffIds  String[] @default([]) // Staff IDs assigned to branch

  // Branch-specific settings
  settings Json? // BranchSettings object

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  primaryStaff       Staff[]             @relation("StaffPrimaryBranch")
  staffAssignments   StaffBranch[]       @relation("StaffBranchAssignments")
  staffSchedules     StaffSchedule[]
  appointments       Appointment[]
  serviceBranches    ServiceBranch[]
  inventories        Inventory[]
  inventoryMovements InventoryMovement[]
  invoices           Invoice[]
  notificationLogs   NotificationLog[]
  
  // Financial relations
  financialAccounts    FinancialAccount[]
  financialTransactions FinancialTransaction[]
  expenses             Expense[]
  budgets              Budget[]
  cashRegisterDays     CashRegisterDay[]
  financialReports     FinancialReport[]
  
  // Sales relations
  sales                Sale[]

  @@index([companyId])
  @@index([type])
  @@index([status])
  @@index([isActive])
  @@index([companyId, status])
  @@index([companyId, isActive])
  @@map("branches")
}

// ============================================================================
// CLIENTS
// ============================================================================

model Client {
  id String @id @default(cuid())

  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Basic information
  firstName   String
  lastName    String
  email       String?
  phone       String?
  dateOfBirth DateTime?
  gender      Gender?

  // Address information
  address Json?

  // Client preferences
  preferredLanguage      String?
  preferredCommunication CommunicationMethod @default(EMAIL)

  // Medical/service history
  allergies         String?
  medicalConditions String?
  notes             String?

  // Marketing and preferences
  marketingConsent    Boolean @default(false)
  reminderPreferences Json?

  // Status
  status   ClientStatus @default(ACTIVE)
  isActive Boolean      @default(true)

  // Metadata
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  appointments Appointment[]
  invoices     Invoice[]
  payments     Payment[]
  sales        Sale[]

  @@index([companyId])
  @@index([email])
  @@index([status])
  @@index([isActive])
  @@index([companyId, status])
  @@index([companyId, isActive])
  @@index([companyId, createdAt])
  @@index([createdAt])
  @@map("clients")
}

// ============================================================================
// STAFF
// ============================================================================

model Staff {
  id String @id @default(cuid())

  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Link to user account (optional for external staff)
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  // Basic information - Enhanced to match Firebase schema
  name           String // Primary name (Arabic support)
  nameAr         String? // Arabic name variant
  firstName      String?
  lastName       String?
  middleName     String?
  title          String? // Job title
  specialization String? // What customers see during online booking
  email          String?
  phone          String?
  mobile         String? // Additional mobile number
  avatar         String?
  image          String? // Profile image URL (Firebase compatibility)
  bio            String? // Staff bio/description

  // Employment details
  employeeId          String?
  positionId          String? // Reference to position for filtering
  position            String? // Keep for backward compatibility
  department          String?
  employmentDate      DateTime? // Hire date
  registrationEndDate DateTime? // Termination date

  // Multi-branch support - Enhanced
  primaryBranchId String? // Primary branch (optional)
  primaryBranch   Branch?       @relation("StaffPrimaryBranch", fields: [primaryBranchId], references: [id])
  branches        StaffBranch[] // Many-to-many branch assignments

  // Access & Authentication
  accessLevel  AccessLevel  @default(EMPLOYEE)
  accessStatus AccessStatus @default(NOT_GRANTED)
  inviteSentAt DateTime?
  lastLoginAt  DateTime?

  // Professional details
  specializations String[]
  certifications  Json?
  qualifications  String?

  // Schedule Management - Enhanced
  isScheduled       Boolean   @default(false)
  scheduleStartDate DateTime? // When the schedule starts
  scheduledUntil    DateTime? // When the schedule ends
  defaultTemplate   String? // Reference to schedule template
  workingHours      Json? // Weekly working hours structure

  // Online Booking Settings
  onlineBookingEnabled Boolean @default(false)
  onlineBookingProfile Json? // Profile description, show rating, etc.
  onlineBookingRules   Json? // Prepayment, any specialist rules
  schedulingTime       String? // 'general' | 'personal'

  // Personal Information
  citizenship String?
  gender      Gender?

  // Documents
  passport        String?
  taxId           String? // Taxpayer Identification Number
  insuranceNumber String?

  // Commission and pay
  commissionRate Decimal? @db.Decimal(5, 4)
  hourlyRate     Decimal? @db.Decimal(8, 2)

  // Display and ordering
  color        String? // For calendar display
  displayOrder Int? // For staff ordering in UI
  order        Int     @default(0) // Firebase-style order field

  // Services count cache
  servicesCount Int @default(0)

  // Status - Enhanced
  status   StaffStatus @default(ACTIVE)
  isActive Boolean     @default(true)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String? // User who created this staff member

  // Relations
  appointments Appointment[]
  services     StaffService[]
  timeOffs     StaffTimeOff[]
  schedules    StaffSchedule[]
  sales        Sale[]

  @@index([companyId])
  @@index([primaryBranchId])
  @@index([positionId])
  @@index([accessLevel])
  @@index([status])
  @@index([isActive])
  @@index([email])
  @@index([order])
  @@index([companyId, status])
  @@index([companyId, isActive])
  @@index([companyId, primaryBranchId])
  @@index([primaryBranchId, status])
  @@map("staff")
}

// ============================================================================
// SERVICES
// ============================================================================

model Service {
  id String @id @default(cuid())

  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Category relationship
  categoryId String?
  category   ServiceCategory? @relation(fields: [categoryId], references: [id])

  // Basic information - Enhanced to match Firebase
  name          String // Primary name (Arabic)
  nameAr        String? // Deprecated - kept for backward compatibility
  description   String?
  descriptionAr String?

  // Multi-language support
  translations Json? // {en: string, fr: string, [key: string]: string}

  // Branch assignments - Enhanced multi-branch support
  branchId  String? // Deprecated - kept for backward compatibility
  branchIds String[] @default([]) // Multiple branch assignments

  // Pricing - Enhanced pricing structure
  startingPrice Decimal @db.Decimal(10, 2) // Base price
  priceRange    Json? // {min: number, max: number}

  // Duration - Enhanced structure
  duration Json // {hours: number, minutes: number}

  // Service type and API integration
  type  ServiceType @default(APPOINTMENT)
  apiId String? // External API integration

  // Online booking settings - Enhanced
  onlineBooking Json // Complete online booking configuration

  // Images and media
  images Json? // Array of image objects with metadata

  // Advanced service options
  invoiceName   String? // Custom invoice name
  taxSystem     String? // Tax system configuration
  vat           Decimal? @db.Decimal(5, 4) // VAT rate
  followUpDays  Int? // Follow-up period in days
  autoDeduction Boolean  @default(false) // Automatic inventory deduction

  // Display and ordering
  color String? // For calendar and UI display
  order Int     @default(0) // Display order

  // Status
  active Boolean @default(true)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String? // User who created the service

  // Relations
  branches      ServiceBranch[]
  staffServices StaffService[]
  saleItems     SaleItem[]

  @@index([companyId])
  @@index([categoryId])
  @@index([active])
  @@index([type])
  @@index([order])
  @@index([companyId, active])
  @@index([companyId, categoryId])
  @@index([companyId, type])
  @@map("services")
}

model ServiceCategory {
  id String @id @default(cuid())

  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Branch assignment for multi-branch support
  branchId String?

  // Basic information
  name   String
  nameAr String?

  // Online booking customization
  useOnlineBookingName Boolean @default(false)
  onlineBookingName    String?

  // Category metadata
  servicesCount Int     @default(0) // Cached count
  description   String?
  color         String? // For UI display
  icon          String? // Icon identifier
  order         Int     @default(0) // Display order

  // Status
  active Boolean @default(true)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String? // User who created the category

  // Relations
  services Service[]

  @@index([companyId])
  @@index([branchId])
  @@index([active])
  @@index([order])
  @@map("service_categories")
}

// ============================================================================
// JUNCTION TABLES
// ============================================================================

model ServiceBranch {
  id        String @id @default(cuid())
  serviceId String
  branchId  String

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  isActive Boolean @default(true)

  @@unique([serviceId, branchId])
  @@map("service_branches")
}

// Staff-Branch Junction Table for Multi-Branch Support
model StaffBranch {
  id       String @id @default(cuid())
  staffId  String
  branchId String

  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  branch Branch @relation("StaffBranchAssignments", fields: [branchId], references: [id], onDelete: Cascade)

  isPrimary Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([staffId, branchId])
  @@index([staffId])
  @@index([branchId])
  @@map("staff_branches")
}

model StaffService {
  id        String @id @default(cuid())
  staffId   String
  serviceId String

  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  // Custom pricing and duration for this staff member
  price    Decimal? @db.Decimal(10, 2) // Override service price
  duration Json? // Override service duration {hours: number, minutes: number}

  // Bill of materials reference
  billOfMaterials String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, serviceId])
  @@map("staff_services")
}

// Staff Schedule Model for Detailed Schedule Management
model StaffSchedule {
  id String @id @default(cuid())

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  // Date range for this schedule
  startDate DateTime
  endDate   DateTime? // Null for indefinite

  // Day of week schedule (0 = Sunday, 6 = Saturday)
  dayOfWeek Int

  // Time slots
  startTime String // "09:00"
  endTime   String // "17:00"

  // Break times
  breaks Json? // Array of {start: "12:00", end: "13:00"}

  // Schedule type
  type      ScheduleType @default(REGULAR)
  isWorking Boolean      @default(true)

  // Override specific dates
  overrideDate DateTime? // For one-time schedule changes

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, branchId, dayOfWeek])
  @@index([staffId])
  @@index([branchId])
  @@index([startDate])
  @@index([dayOfWeek])
  @@map("staff_schedules")
}

// ============================================================================
// APPOINTMENTS
// ============================================================================

model Appointment {
  id         String  @id @default(cuid())
  companyId  String
  branchId   String
  clientId   String
  staffId    String?
  resourceId String? // For resource-based appointments

  // Client Information (denormalized for performance)
  clientName  String
  clientPhone String
  clientEmail String?
  isNewClient Boolean @default(false)

  // Staff Information (denormalized for performance)
  staffName String?

  // Scheduling
  date          DateTime
  startTime     String // "09:00"
  endTime       String // "10:30"
  duration      Int? // in minutes (legacy)
  totalDuration Int // in minutes

  // Services - Enhanced to support multiple services per appointment
  services   Json // Array of service objects with details
  categoryId String?
  totalPrice Decimal @db.Decimal(10, 2)

  // Status
  status        AppointmentStatus @default(PENDING)
  paymentStatus PaymentStatus     @default(PENDING)

  // Recurring
  isRecurring      Boolean @default(false)
  recurringPattern Json? // Recurring configuration
  recurringGroupId String? // Links recurring appointments
  repeat           Json? // Legacy Firebase repeat structure
  repeatGroupId    String? // Legacy Firebase field

  // Details
  title         String?
  notes         String?
  internalNotes String? // staff-only notes
  color         String?

  // Pricing
  startingPrice Decimal? @db.Decimal(10, 2)
  prepaidAmount Decimal? @db.Decimal(10, 2)
  paidAmount    Decimal  @default(0) @db.Decimal(10, 2)
  discount      Decimal? @db.Decimal(10, 2)

  // Resources
  resources Json? // Array of resource objects

  // Metadata
  source         AppointmentSource @default(DASHBOARD)
  bookingLinkId  String? // if booked online
  createdBy      String?
  lastModifiedBy String?

  // Cancellation Info
  cancelledBy        String? // 'client' | 'staff' | 'system'
  cancelledAt        DateTime?
  cancellationReason String?

  // Reschedule Info
  rescheduledTo String? // ID of the new appointment
  rescheduledAt DateTime?

  // Notifications
  notifications Json? // Array of notification objects
  reminderSent  Boolean @default(false)

  // Change tracking
  changeHistory Json? // Array of change history objects

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  company   Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch                @relation(fields: [branchId], references: [id])
  client    Client                @relation(fields: [clientId], references: [id])
  staff     Staff?                @relation(fields: [staffId], references: [id])
  invoices  AppointmentInvoice[]
  reminders AppointmentReminder[]
  invoice   Invoice?

  @@index([companyId, branchId, date])
  @@index([clientId])
  @@index([staffId])
  @@index([date, startTime])
  @@index([status])
  @@index([recurringGroupId])
  @@index([source])
  @@index([companyId, status])
  @@index([branchId, date, status])
  @@index([staffId, date, startTime])
  @@index([clientId, createdAt])
  @@index([date, status])
  @@index([companyId, date, status])
  @@map("appointments")
}

model AppointmentReminder {
  id            String       @id @default(cuid())
  appointmentId String
  type          ReminderType
  scheduledFor  DateTime
  sent          Boolean      @default(false)
  sentAt        DateTime?
  error         String?

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@index([scheduledFor, sent])
  @@map("appointment_reminders")
}

enum ReminderType {
  SMS
  EMAIL
  WHATSAPP
  PUSH
}

model AppointmentWaitlist {
  id               String   @id @default(cuid())
  companyId        String
  branchId         String
  clientId         String
  serviceIds       Json
  preferredStaffId String?
  preferredDate    DateTime
  flexibleDates    Boolean  @default(false)
  notes            String?
  status           String   @default("WAITING")
  createdAt        DateTime @default(now())

  @@index([branchId, preferredDate])
  @@map("appointment_waitlist")
}

// ============================================================================
// INVOICING AND PAYMENTS
// ============================================================================

model Invoice {
  id String @id @default(cuid())

  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Branch relationship (required)
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  // Invoice details
  invoiceNumber String
  title         String?

  // Client relationship
  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  // Optional appointment relationship
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  // Dates
  invoiceDate DateTime @default(now())
  issueDate   DateTime @default(now()) // Deprecated: use invoiceDate
  dueDate     DateTime

  // Financial details
  subtotal       Decimal  @default(0) @db.Decimal(10, 2)
  taxRate        Decimal  @default(0) @db.Decimal(5, 4)
  taxAmount      Decimal  @default(0) @db.Decimal(10, 2)
  discountAmount Decimal  @default(0) @db.Decimal(10, 2)
  discountType   String? // PERCENTAGE, FIXED
  discountValue  Decimal? @db.Decimal(10, 2)
  total          Decimal  @default(0) @db.Decimal(10, 2)

  // Payment tracking
  status        InvoiceStatus @default(DRAFT)
  paymentStatus PaymentStatus @default(PENDING)
  paidAmount    Decimal       @default(0) @db.Decimal(10, 2)
  balanceAmount Decimal       @default(0) @db.Decimal(10, 2) // Calculated: total - paidAmount

  // Currency and localization
  currency String @default("EGP")

  // Additional information
  notes           String?
  internalNotes   String?
  terms           String?
  termsConditions String?

  // Status tracking
  sentAt      DateTime?
  viewedAt    DateTime?
  paidAt      DateTime?
  cancelledAt DateTime?

  // Metadata
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  items        InvoiceItem[]
  appointments AppointmentInvoice[]
  payments     Payment[]
  sales        Sale[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId])
  @@index([branchId])
  @@index([clientId])
  @@index([appointmentId])
  @@index([status])
  @@index([paymentStatus])
  @@index([dueDate])
  @@index([invoiceDate])
  @@index([companyId, status])
  @@index([companyId, paymentStatus])
  @@index([branchId, status])
  @@index([clientId, status])
  @@index([companyId, dueDate])
  @@index([status, dueDate])
  @@map("invoices")
}

model InvoiceItem {
  id String @id @default(cuid())

  // Invoice relationship
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Item type and reference
  type   String // SERVICE, PRODUCT, CUSTOM
  itemId String? // Reference to service/product ID

  // Item details
  description String
  quantity    Decimal  @db.Decimal(10, 3)
  unitPrice   Decimal  @db.Decimal(10, 2)
  discount    Decimal? @db.Decimal(10, 2) // Item-level discount
  taxRate     Decimal? @db.Decimal(5, 4) // Item-level tax rate
  total       Decimal  @db.Decimal(10, 2)

  // Ordering
  order Int @default(0)

  @@index([invoiceId])
  @@index([type])
  @@index([itemId])
  @@map("invoice_items")
}

model AppointmentInvoice {
  id String @id @default(cuid())

  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, invoiceId])
  @@map("appointment_invoices")
}

model Payment {
  id String @id @default(cuid())

  // Multi-tenant relationship
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Payment details
  amount        Decimal       @db.Decimal(10, 2)
  paymentDate   DateTime      @default(now())
  paymentMethod PaymentMethod
  reference     String? // Payment reference number

  // Relationships
  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  // Payment processing
  transactionId  String?
  paymentGateway String?
  processedAt    DateTime?

  // Status
  status PaymentStatus @default(PENDING)

  // Additional information
  notes String?

  // Metadata
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([clientId])
  @@index([invoiceId])
  @@index([status])
  @@index([paymentDate])
  @@map("payments")
}

// ============================================================================
// STAFF MANAGEMENT
// ============================================================================

model StaffTimeOff {
  id String @id @default(cuid())

  staffId String
