# Backend API URL
VITE_API_URL=http://localhost:3005/api/v1

# Force Express backend mode (set all to true for PostgreSQL/Prisma backend)
VITE_FORCE_EXPRESS_MODE=true
VITE_USE_EXPRESS_SERVICES=true
VITE_USE_EXPRESS_STAFF=true
VITE_USE_EXPRESS_BRANCHES=true
VITE_USE_EXPRESS_PRODUCTS=true
VITE_USE_EXPRESS_CLIENTS=true
VITE_USE_EXPRESS_APPOINTMENTS=true
VITE_USE_EXPRESS_INVOICES=true
VITE_USE_EXPRESS_PAYMENTS=true
VITE_USE_EXPRESS_REPORTS=true

# Feature flags
VITE_USE_WEBSOCKET=false
VITE_ENABLE_FALLBACK=false
VITE_ENABLE_CACHING=true
